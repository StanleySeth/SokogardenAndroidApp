<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_height="wrap_content">
    
<!--    Below is a CardView-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="10dp"
        android:elevation="15dp"
        app:cardCornerRadius="12dp"
        android:layout_margin="10dp">

<!--        Below is another LinearLayout that dictates how the contents will be aligned inside the CardView-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#00BCD4">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_name"
                android:textSize="25dp"
                android:text="Product Name"
                android:textAlignment="center"
                android:textColor="#B5F4CE"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

<!--                Below is our product_image-->
                <ImageView
                    android:id="@+id/product_photo"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="centerCrop"
                    android:layout_marginTop="3dp" />

<!--            Below is a TextView of the Product_cost-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_cost"
                android:textSize="25dp"
                android:text="KES 500"
                android:layout_marginTop="5dp"
                android:textStyle="bold"
                android:textColor="#FFEB3B" />

<!--            Below is the textView of the product_description-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_description"
                android:textSize="20dp"
                android:text="The product description will appear here..."
                android:layout_marginTop="5dp"
                android:textColor="#FFFFFF"
                android:textStyle="italic"
                android:layout_marginLeft="10dp" />

<!--            Below is our purchase button-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/btnPurchase"
                android:text="APPLY FOR THE SESSION"
                android:textSize="20dp"
                android:layout_marginTop="5dp"
                android:layout_marginLeft="70dp"
                android:layout_marginRight="70dp"
                android:backgroundTint="#418224"
                android:textColor="#FFFFFF" />


        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>